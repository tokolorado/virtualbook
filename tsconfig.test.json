{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "tsBuildInfoFile": ".test-dist/tsconfig.tsbuildinfo",
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "lib/odds/labels.ts",
    "lib/odds/poisson.ts",
    "lib/bets/slipPricing.ts",
    "lib/bets/betBuilderPricing.ts",
    "lib/missions.ts",
    "lib/requireCronSecret.ts"
  ]
}
